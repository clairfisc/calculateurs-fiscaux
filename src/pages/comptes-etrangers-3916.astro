---
import BaseLayout from "../layouts/BaseLayout.astro";
import ChecklistComptes from "../components/comptes-3916/ChecklistComptes.tsx";
import Disclaimer from "../components/content/Disclaimer.astro";
import { ETABLISSEMENTS } from "../lib/comptes-3916";

const title =
  "Quels comptes étrangers déclarer ? Checklist 3916 / 3916-bis (2026)";
const description =
  "Banque, néobanque, courtier, exchange crypto, PayPal : quels comptes étrangers devez-vous déclarer aux impôts (formulaire 3916 / 3916-bis) ? Checklist gratuite, verdict par compte et fiche à recopier. 100 % local, sans compte ni tracker.";
---

<BaseLayout title={title} description={description}>
    <main>
      <!-- Checklist : îlot React hydraté côté client -->
      <ChecklistComptes client:load />

      <!-- Contenu / SEO -->
      <section class="mx-auto w-full max-w-4xl px-4 pb-10">
        <Disclaimer />

        <article class="prose-clairfisc mt-6 text-sm text-slate-700">
          <h2 class="mb-2 text-base font-semibold text-slate-900">L'essentiel sur la déclaration des comptes étrangers</h2>
          <p>
            Depuis le 1<sup>er</sup> janvier 2019, tout résident fiscal français doit déclarer
            <strong>chaque compte ouvert, détenu, utilisé ou clos à l'étranger</strong> au cours de l'année — y
            compris un compte <strong>vide ou dormant</strong> (l'obligation porte sur l'existence du compte, pas
            sur son activité). Les comptes d'<strong>actifs numériques</strong> (Binance, Kraken, Coinbase…)
            relèvent du formulaire <strong>3916-bis</strong> et se déclarent même sans aucune opération.
          </p>
          <p class="mt-2">
            Une <strong>exemption</strong> existe pour les comptes de monnaie électronique (type PayPal) à trois
            conditions cumulatives : usage limité aux paiements / encaissements de <em>ventes de biens</em> en ligne,
            adossement à un compte ouvert en France, et encaissements annuels n'excédant pas 10 000 €.
          </p>
          <p class="mt-2">
            Le défaut de déclaration est sanctionné : <strong>1 500 €</strong> par compte bancaire (10 000 € pour un
            État sans convention d'assistance administrative) et <strong>750 €</strong> par compte d'actifs numériques.
          </p>
          <p class="mt-2 text-xs text-slate-500">
            Sources : CGI art. 1649 A, 1649 bis C, 1736 ; BOFiP BOI-CF-CPF-30-20. Outil d'aide informative, ne
            remplace pas la doctrine officielle ni un conseil professionnel.
          </p>

          <nav class="mt-6" aria-label="Par établissement">
            <h2 class="mb-2 text-base font-semibold text-slate-900">Déclarer un compte par établissement</h2>
            <ul class="flex flex-wrap gap-x-4 gap-y-1 text-blue-700">
              {ETABLISSEMENTS.map((e) => (
                <li>
                  <a class="underline" href={`/declarer-compte/${e.id}`}>Compte {e.designation}</a>
                </li>
              ))}
            </ul>
          </nav>
        </article>
      </section>
    </main>
</BaseLayout>
